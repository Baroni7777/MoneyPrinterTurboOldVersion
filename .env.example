# MoneyPrinterTurbo environment configuration
#
# Environment variables override config.toml when they are non-empty.
# The preferred naming is MPT_<SECTION>_<KEY>, for example:
#   MPT_APP_ENDPOINT, MPT_APP_OPENAI_API_KEY, MPT_WHISPER_DEVICE
# For [app] keys, the shorter MPT_<KEY> form is also accepted.
# Empty or missing variables keep the value from config.toml.

# Public deployment addresses
MPT_APP_ENDPOINT=https://vid.api.example.com
MPT_PUBLIC_ENDPOINT=https://vid.api.example.com

# API server
MPT_LOG_LEVEL=INFO
MPT_LISTEN_HOST=0.0.0.0
MPT_LISTEN_PORT=8080

# Video/material providers
MPT_APP_VIDEO_SOURCE=pexels
MPT_APP_PEXELS_API_KEYS=["your-pexels-key"]
MPT_APP_PIXABAY_API_KEYS=[]
MPT_APP_COVERR_API_KEYS=[]
MPT_APP_TWELVELABS_API_KEYS=[]
MPT_APP_TWELVELABS_RERANK_TERMS=false
MPT_APP_MATCH_MATERIALS_TO_SCRIPT=false

# LLM provider
MPT_APP_LLM_PROVIDER=openai
MPT_APP_OPENAI_API_KEY=replace-me
MPT_APP_OPENAI_BASE_URL=
MPT_APP_OPENAI_MODEL_NAME=

# Other supported providers (fill only the provider you use)
MPT_APP_MOONSHOT_API_KEY=
MPT_APP_DEEPSEEK_API_KEY=
MPT_APP_QWEN_API_KEY=
MPT_APP_GEMINI_API_KEY=
MPT_APP_GROQ_API_KEY=
MPT_APP_GROK_API_KEY=
MPT_APP_MINIMAX_API_KEY=
MPT_APP_MIMO_API_KEY=
MPT_APP_CLOUDFLARE_API_KEY=
MPT_APP_CLOUDFLARE_ACCOUNT_ID=
MPT_APP_MODELSCOPE_API_KEY=
MPT_APP_AIHUBMIX_API_KEY=
MPT_APP_AIMLAPI_API_KEY=
MPT_APP_EVOLINK_API_KEY=
MPT_APP_ONEAPI_API_KEY=
MPT_APP_POLLINATIONS_API_KEY=

# Speech, subtitles, and encoding
MPT_APP_SUBTITLE_PROVIDER=edge
MPT_WHISPER_MODEL_SIZE=large-v3
MPT_WHISPER_DEVICE=cpu
MPT_WHISPER_COMPUTE_TYPE=int8
MPT_AZURE_SPEECH_KEY=
MPT_AZURE_SPEECH_REGION=

# Optional Chatterbox / ElevenLabs
MPT_CHATTERBOX_BASE_URL=http://127.0.0.1:4123/v1
MPT_CHATTERBOX_API_KEY=
MPT_CHATTERBOX_MODEL_ID=chatterbox
MPT_CHATTERBOX_VOICES=["default-Female"]
MPT_ELEVENLABS_API_KEY=
MPT_ELEVENLABS_MODEL_ID=
MPT_ELEVENLABS_MUSIC_MODEL_ID=music_v2
MPT_ELEVENLABS_MUSIC_TIMEOUT=600

# Runtime/storage
MPT_APP_MATERIAL_DIRECTORY=
MPT_APP_ENABLE_REDIS=false
MPT_APP_REDIS_HOST=localhost
MPT_APP_REDIS_PORT=6379
MPT_APP_REDIS_DB=0
MPT_APP_REDIS_PASSWORD=
MPT_APP_MAX_CONCURRENT_TASKS=5
MPT_APP_MAX_QUEUED_TASKS=100

# Publishing (optional)
MPT_APP_UPLOAD_POST_ENABLED=false
MPT_APP_UPLOAD_POST_API_KEY=
MPT_APP_UPLOAD_POST_USERNAME=
MPT_APP_UPLOAD_POST_PLATFORMS=["tiktok", "instagram"]
MPT_APP_UPLOAD_POST_AUTO_UPLOAD=false
